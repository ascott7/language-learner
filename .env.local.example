# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Path to your Anki collection on the host machine (mounted into Docker)
# macOS default: ~/Library/Application Support/Anki2/User 1/collection.anki2
ANKI_DB_PATH=/path/to/collection.anki2

# Python Anki service URL (Docker)
ANKI_SERVICE_URL=http://localhost:5000

# App SQLite database path
APP_DB_PATH=./data/language-learner.db
